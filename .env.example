# ── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pole_emploi:changeme@db:5432/pole_emploi_db
POSTGRES_USER=pole_emploi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pole_emploi_db

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── France Travail / Pôle Emploi API ─────────────────────────────────────────
FRANCETRAVAIL_CLIENT_ID=your-client-id
FRANCETRAVAIL_CLIENT_SECRET=your-client-secret
FRANCETRAVAIL_API_BASE_URL=https://api.francetravail.io/partenaire

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-secret-key-in-production
ALLOWED_ORIGINS=http://localhost:3000
DEBUG=true

# ── Scheduler (Celery Beat) ───────────────────────────────────────────────────
# Format cron : minute heure jour mois jour_semaine
CV_AUDIT_SCHEDULE_CRON=0 9 1 * *    # 1er du mois à 9h
CV_AUDIT_DEFAULT_RECIPIENT=user@example.com
